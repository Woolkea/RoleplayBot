{
  "name": "lunar-bot",
  "version": "0.1.0",
  "private": true,
  "description": "LunarRP Discord bot (discord.js, TypeScript, PostgreSQL, Drizzle)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Woolkea/LunarRP.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "dev": "tsx src/scripts/dev.ts",
    "dev:app": "tsx watch src/index.ts",
    "db:up": "docker compose up -d",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:reset-local": "tsx src/scripts/db-reset-local.ts",
    "db:studio": "drizzle-kit studio",
    "register-commands": "tsx src/scripts/register-commands.ts"
  },
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "@napi-rs/canvas": "^0.1.100",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.19.1",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
